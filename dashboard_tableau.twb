    <worksheet name='Evolución voto nacionalista e independentistas '>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1'>Evolución del voto nacionalista e independentista</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='final_master' name='federated.0g76v301txgpbe16benlr0h245qr' />
          </datasources>
          <datasource-dependencies datasource='federated.0g76v301txgpbe16benlr0h245qr'>
            <column caption='Región' datatype='string' name='[Calculation_1337287641885609988]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IF [codigo_provincia] = 8 OR [codigo_provincia] = 17 OR [codigo_provincia] = 25 OR [codigo_provincia] = 43 THEN &quot;Cataluña&quot;&#13;&#10;ELSEIF [codigo_provincia] = 1 OR [codigo_provincia] = 20 OR [codigo_provincia] = 48 OR [codigo_provincia] = 31 THEN &quot;País Vasco + Navarra&quot;&#13;&#10;ELSE &quot;Otros&quot;&#13;&#10;END' />
            </column>
            <column caption='Es Nacionalista' datatype='string' name='[Calculation_1337287641886814215]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='CASE [siglas_unificadas]&#13;&#10;WHEN &apos;JUNTS_CIU&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;WHEN &apos;ERC&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;WHEN &apos;CUP&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;WHEN &apos;PNV&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;WHEN &apos;BILDU_HB&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;WHEN &apos;EA&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;WHEN &apos;GEROA_BAI&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;ELSE &apos;No Nacionalista&apos;&#13;&#10;END' />
            </column>
            <column caption='Porcentaje de votos nacionalista' datatype='real' name='[Calculation_1337287641886949384]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM(IF [Calculation_1337287641886814215] = &apos;Nacionalismo&apos; THEN [votos] END) / SUM([votos])' />
