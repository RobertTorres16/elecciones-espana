      <aliases enabled='yes' />
      <column caption='Bando Politico' datatype='string' name='[Calculation_1337287641864699904]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [siglas_unificadas] = &apos;BILDU_HB&apos; &#13;&#10;OR [siglas_unificadas] = &apos;BNG&apos; &#13;&#10;OR [siglas_unificadas] = &apos;CC_NC&apos; &#13;&#10;OR [siglas_unificadas] = &apos;COALICION_GALEGA&apos; &#13;&#10;OR [siglas_unificadas] = &apos;CUP&apos; &#13;&#10;OR [siglas_unificadas] = &apos;EA&apos; &#13;&#10;OR [siglas_unificadas] = &apos;ERC&apos; &#13;&#10;OR [siglas_unificadas] = &apos;ESPANA_VACIADA&apos; &#13;&#10;OR [siglas_unificadas] = &apos;FORO_ASTURIAS&apos; &#13;&#10;OR [siglas_unificadas] = &apos;GEROA_BAI&apos; &#13;&#10;OR [siglas_unificadas] = &apos;GIL_POPULISMO&apos; &#13;&#10;OR [siglas_unificadas] = &apos;JUNTS_CIU&apos; &#13;&#10;OR [siglas_unificadas] = &apos;PAR_ARAGON&apos; &#13;&#10;OR [siglas_unificadas] = &apos;PARTIDO_ANDALUCISTA&apos; &#13;&#10;OR [siglas_unificadas] = &apos;PNV&apos; &#13;&#10;OR [siglas_unificadas] = &apos;PRC_CANTABRIA&apos; &#13;&#10;OR [siglas_unificadas] = &apos;UNIO_VALENCIANA&apos; &#13;&#10;OR [siglas_unificadas] = &apos;UPL_LEON&apos; &#13;&#10;THEN &quot;Regionalista / Indep&quot;&#13;&#10;ELSE &quot;Nacional / Estatal&quot;&#13;&#10;END' />
      </column>
      <column caption='Votos nacionales ' datatype='integer' name='[Calculation_1337287641866272769]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1337287641864699904] = &quot;Nacional / Estatal&quot; THEN [votos] END' />
      </column>
      <column caption='Votos regionales ' datatype='integer' name='[Calculation_1337287641866465282]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_1337287641864699904] = &quot;Regionalista / Indep&quot; THEN -[votos] END' />
      </column>
      <column caption='Ranking para filtro' datatype='integer' name='[Calculation_1337287641875021827]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RANK(SUM([votos]))'>
          <table-calc ordering-type='Rows' />
        </calculation>
      </column>
      <column caption='Región' datatype='string' name='[Calculation_1337287641885609988]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [codigo_provincia] = 8 OR [codigo_provincia] = 17 OR [codigo_provincia] = 25 OR [codigo_provincia] = 43 THEN &quot;Cataluña&quot;&#13;&#10;ELSEIF [codigo_provincia] = 1 OR [codigo_provincia] = 20 OR [codigo_provincia] = 48 OR [codigo_provincia] = 31 THEN &quot;País Vasco + Navarra&quot;&#13;&#10;ELSE &quot;Otros&quot;&#13;&#10;END' />
      </column>
      <column caption='Bloque nacionalista' datatype='string' name='[Calculation_1337287641885749253]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [siglas_unificadas]&#13;&#10;WHEN &apos;JUNTS_CIU&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;WHEN &apos;ERC&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;WHEN &apos;CUP&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;WHEN &apos;PNV&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;WHEN &apos;BILDU_HB&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;WHEN &apos;EA&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;WHEN &apos;GEROA_BAI&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;ELSE &apos;No Nacionalista&apos;&#13;&#10;END' />
      </column>
      <column caption='Es Nacionalista' datatype='string' name='[Calculation_1337287641886814215]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CASE [siglas_unificadas]&#13;&#10;WHEN &apos;JUNTS_CIU&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;WHEN &apos;ERC&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;WHEN &apos;CUP&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;WHEN &apos;PNV&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;WHEN &apos;BILDU_HB&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;WHEN &apos;EA&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;WHEN &apos;GEROA_BAI&apos; THEN &apos;Nacionalismo&apos;&#13;&#10;ELSE &apos;No Nacionalista&apos;&#13;&#10;END' />
      </column>
      <column caption='Porcentaje de votos nacionalista' datatype='real' name='[Calculation_1337287641886949384]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Calculation_1337287641886814215] = &apos;Nacionalismo&apos; THEN [votos] END) / SUM([votos])' />
      </column>
      <column caption='Cálculo1' datatype='string' name='[Calculation_1337287641896497161]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[porcentaje]' />
      </column>
      <column caption='Intensidad ganador ' datatype='string' name='[Calculation_1337287641896742922]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [votos] = [Calculation_1808758227770671114] THEN [porcentaje] END' />
      </column>
      <column caption='Fecha' datatype='date' name='[Calculation_1808758227764576256]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='MAKEDATE([anno], [mes], 1)' />
      </column>
      <column caption='Porcentaje_be' datatype='real' name='[Calculation_1808758227764715521]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='FLOAT([porcentaje])' />
      </column>
      <column caption='votos max provincia' datatype='integer' name='[Calculation_1808758227770671114]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [anno], [mes], [codigo_provincia] : MAX([votos])}' />
      </column>
      <column caption='Partido ganador' datatype='string' name='[Calculation_1808758227772055564]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF INT([votos]) = [Calculation_1808758227770671114] THEN [siglas_unificadas] END' />
      </column>
      <column caption='Porcentaje nacional' datatype='real' name='[Calculation_1808758227777359885]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([votos]) / SUM({FIXED [anno], [mes] : SUM([votos])})' />
      </column>
      <column caption='Porcentaje nacional real' datatype='real' name='[Calculation_1808758227780091918]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([votos]) / SUM({FIXED [anno], [mes] : SUM([votos])})' />
      </column>
